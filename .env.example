# ArGen - Environment Configuration Template
# Duplicate this file to '.env' and fill in your actual values.
# DO NOT commit your actual '.env' file containing real secrets to version control.

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection
# Set your local mongodb:// URI or MongoDB Atlas standard connection string (mongodb+srv://)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/argen?retryWrites=true&w=majority

# Authentication Secrets
JWT_SECRET=your_jwt_secret_hex_here

# Superadmin & Bypass Credentials for Testing
ADMIN_EMAIL=admin@argen
ADMIN_PASSWORD=argen@admin

# Google OAuth Configuration (Authentication)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# API & Features Proxy
AI_API_KEY=your_argen_internal_ai_api_key_here

# AI Provider Stack Keys
# ArGen uses a fallback mechanism: Anthropic (Primary) -> Gemini (Fallback) -> OpenAI (Secondary Fallback)
ANTHROPIC_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-proj-...

# Nodemailer Email Configuration (for Pilot Approval & Invitations)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
# Use an App Password if using Gmail, not your normal password
EMAIL_PASS=your_gmail_app_password_here

# Whop payment platform integration
WHOP_API_KEY=apik_...
WHOP_WEBHOOK_SECRET=ws_...
NEXT_PUBLIC_WHOP_APP_ID=app_...

# Cron Scheduling Secret (Secures automation endpoints from unauthorized invocations)
CRON_SECRET=your_cron_secret_here
