nid": "js_script_initauthui", "callee": "getElementById", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L305"}, {"caller_nid": "js_script_initauthui", "callee": "querySelector", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L306"}, {"caller_nid": "js_script_initauthui", "callee": "getElementById", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L312"}, {"caller_nid": "js_script_initauthui", "callee": "createElement", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L313"}, {"caller_nid": "js_script_initauthui", "callee": "appendChild", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L318"}, {"caller_nid": "js_script_initauthui", "callee": "getElementById", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L321"}, {"caller_nid": "js_script_initauthui", "callee": "createElement", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L322"}, {"caller_nid": "js_script_initauthui", "callee": "appendChild", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L327"}, {"caller_nid": "js_script_initauthui", "callee": "(async function initOrgSwitcher() {\n        try {\n          const res = await fetch('/api/auth/my-companies', {\n            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }\n          });\n          if (!res.ok) return;\n          const companies = await res.json();\n          if (!Array.isArray(companies) || companies.length <= 1) return;\n          const activeId = localStorage.getItem('active_company_id') || companies[0].companyId;\n          const active = companies.find(c => c.companyId === activeId) || companies[0];\n          if (!localStorage.getItem('active_company_id')) {\n            localStorage.setItem('active_company_id', active.companyId);\n          }\n          const wrapper = document.createElement('div');\n          wrapper.style.cssText = 'position:relative;display:inline-block;margin-left:12px;';\n          wrapper.innerHTML = `\n            <button id=\"orgSwitcherBtn\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:6px;padding:4px 12px;color:#fff;font-size:0.7rem;font-family:var(--font-mono);cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:6px;\">\n              <span style=\"width:6px;height:6px;border-radius:50%;background:var(--accent);display:inline-block;\"></span>\n              ${active.name}\n              <span style=\"font-size:0.5rem;opacity:0.5;\">\u25bc</span>\n            </button>\n            <div id=\"orgSwitcherDropdown\" style=\"display:none;position:absolute;top:100%;left:0;margin-top:4px;background:#141414;border:1px solid rgba(255,255,255,0.08);border-radius:8px;min-width:180px;z-index:100;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,0.4);\">\n              ${companies.map(c => `\n                <div class=\"org-switcher-item\" data-id=\"${c.companyId}\" style=\"padding:8px 14px;cursor:pointer;font-size:0.75rem;color:${c.companyId === active.companyId ? 'var(--accent)' : '#ccc'};border-bottom:1px solid rgba(255,255,255,0.04);display:flex;align-items:center;gap:8px;transition:background 0.15s;\">\n                  <span style=\"width:6px;height:6px;border-radius:50%;background:${c.companyId === active.companyId ? 'var(--accent)' : 'rgba(255,255,255,0.15)'};display:inline-block;flex-shrink:0;\"></span>\n                  <span style=\"flex:1;\">${c.name}</span>\n                  <span style=\"font-size:0.6rem;opacity:0.4;text-transform:uppercase;\">${c.role}</span>\n                </div>\n              `).join('')}\n            </div>\n          `;\n          navLinks.appendChild(wrapper);\n\n          // Toggle dropdown\n          document.getElementById('orgSwitcherBtn').addEventListener('click', (e) => {\n            e.stopPropagation();\n            const dd = document.getElementById('orgSwitcherDropdown');\n            dd.style.display = dd.style.display === 'none' ? 'block' : 'none';\n          });\n          document.addEventListener('click', () => {\n            document.getElementById('orgSwitcherDropdown').style.display = 'none';\n          });\n\n          // Switch company\n          document.querySelectorAll('.org-switcher-item').forEach(el => {\n            el.addEventListener('click', async () => {\n              const companyId = el.dataset.id;\n              if (companyId === activeId) return;\n              try {\n                await fetch('/api/auth/switch-company', {\n                  method: 'POST',\n                  headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },\n                  body: JSON.stringify({ companyId })\n                });\n                localStorage.setItem('active_company_id', companyId);\n                localStorage.setItem('company_switched', 'true');\n                window.location.reload();\n              } catch (e) {\n                console.error('Switch failed:', e);\n              }\n            });\n          });\n        } catch (e) { /* silently fail */ }\n      })", "is_member_call": false, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L331"}, {"caller_nid": "js_script_initauthui", "callee": "fetch", "is_member_call": false, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L333"}, {"caller_nid": "js_script_initauthui", "callee": "json", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L337"}, {"caller_nid": "js_script_initauthui", "callee": "isArray", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L338"}, {"caller_nid": "js_script_initauthui", "callee": "getItem", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L339"}, {"caller_nid": "js_script_initauthui", "callee": "find", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L340"}, {"caller_nid": "js_script_initauthui", "callee": "getItem", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L341"}, {"caller_nid": "js_script_initauthui", "callee": "setItem", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L342"}, {"caller_nid": "js_script_initauthui", "callee": "createElement", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L344"}, {"caller_nid": "js_script_initauthui", "callee": "join", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L353"}, {"caller_nid": "js_script_initauthui", "callee": "map", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/script.js", "source_location": "L353"}, {"caller_nid": "js_script_initauthui", "callee": "appendChild", "is_member_call": true, "source_file": "/Users/lakshitsinghvi/Documents/ArGen - New Look/frontend/js/scri