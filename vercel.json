{
  "version": 2,
  "name": "argen-frontend",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/", "destination": "/frontend/html/index.html" },
    { "source": "/about", "destination": "/frontend/html/about.html" },
    { "source": "/pricing", "destination": "/frontend/html/pricing.html" },
    { "source": "/contact", "destination": "/frontend/html/contact.html" },
    { "source": "/admin-portal", "destination": "/frontend/html/admin-portal.html" },
    { "source": "/admin-access", "destination": "/frontend/html/admin-access.html" },
    { "source": "/evaluate", "destination": "/frontend/html/evaluate.html" },
    { "source": "/challenges", "destination": "/frontend/html/challenges.html" },
    { "source": "/login", "destination": "/frontend/html/login.html" },
    { "source": "/oauth", "destination": "/frontend/html/oauth.html" },
    { "source": "/forgot-password", "destination": "/frontend/html/forgot-password.html" },
    { "source": "/reset-password", "destination": "/frontend/html/reset-password.html" },
    { "source": "/teams", "destination": "/frontend/html/teams.html" },
    { "source": "/team/:id", "destination": "/frontend/html/team-detail.html" },
    { "source": "/privacy", "destination": "/frontend/html/privacy.html" },
    { "source": "/terms", "destination": "/frontend/html/terms.html" },
    { "source": "/waitlist", "destination": "/frontend/html/waitlist.html" },
    { "source": "/registration", "destination": "/frontend/html/registration.html" },
    { "source": "/invoice", "destination": "/frontend/html/invoice.html" },
    { "source": "/dashboard", "destination": "/frontend/html/dashboard.html" },
    { "source": "/take-evaluation", "destination": "/frontend/html/take-evaluation.html" },
    { "source": "/connect", "destination": "/frontend/html/connect.html" },
    { "source": "/onboarding", "destination": "/frontend/html/onboarding.html" },
    { "source": "/payment-success", "destination": "/frontend/html/payment-success.html" },
    { "source": "/payment-failed", "destination": "/frontend/html/payment-failed.html" },
    { "source": "/cookie-policy", "destination": "/frontend/html/cookie-policy.html" },
    { "source": "/gdpr", "destination": "/frontend/html/gdpr.html" },
    { "source": "/dpa", "destination": "/frontend/html/dpa.html" },
    { "source": "/aup", "destination": "/frontend/html/aup.html" },
    { "source": "/(css|js|images)/(.*)", "destination": "/frontend/$1/$2" }
  ],
  "crons": [
    {
      "path": "/api/scheduler/daily-nudges",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/scheduler/weekly-reports",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/scheduler/streak-check",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/scheduler/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/scheduler/sync-connections",
      "schedule": "0 */6 * * *"
    }
  ]
}
